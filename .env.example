DATABASE_URL="file:./dev.db"

# OpenAI-compatible AI provider config.
# OpenAI 直接填 OPENAI_API_KEY 或 AI_API_KEY 都可以。
# DeepSeek / 其他兼容接口建议优先填下面这组 AI_*。
AI_API_KEY=""
AI_BASE_URL=""
AI_MODEL="gpt-4.1-mini"
AI_VISION_MODEL=""
AI_SUPPORTS_VISION="true"

# 兼容旧配置
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-4.1-mini"

# DingTalk 群机器人 Webhook
DINGTALK_WEBHOOK_URL=""
# 可选：机器人开启“加签”安全时填写
DINGTALK_SECRET=""

# 自动提醒（可选）
# 每日摘要触发时间（24小时制，HH:mm）
REMINDER_DAILY_TIME="08:30"
# 建议配置：用于保护 /api/reminders/run 接口
REMINDER_RUN_TOKEN=""
